# ============================================================
#  Ortho4XP_V3 — .gitignore
#  À placer à la RACINE de votre dossier Ortho4XP_V3
# ============================================================

# ── Dossiers de données lourds personnels ───────────────────
Tiles/
Orthophotos/
Elevation_data/
Extents/
OSM/
OSM_data/
Masks/
Imagery/
tmp/
Tmp/
Cache/
Custom_scenery/
Output/
Geotiffs/

# ── Cache tuiles généré par O4_Dependency.py ────────────────
Ortho/

# ── Providers personnels (garder uniquement Global et O4_Custom_URL.py) ──
Providers/Austria/
Providers/Belgium/
Providers/Croatia/
Providers/Czech_Republic_and_Slovakia/
Providers/Denmark/
Providers/Espagne/
Providers/Estonia/
Providers/Faroe/
Providers/Finland/
Providers/France/
Providers/France*/
Providers/Germany/
Providers/Hollande/
Providers/Hungary/
Providers/Israel/
Providers/Italy/
Providers/Japan/
Providers/Luxembourg/
Providers/New_Zealand/
Providers/Norway/
Providers/Poland/
Providers/Slovenia/
Providers/Suisse/
Providers/Sweden/
Providers/United_States/
Providers/EUR.comb
Providers/ZonePhoto.comb
Providers/__pycache__/
Providers/Global/Mapbox.lay

# ── Fichiers de configuration personnels ────────────────────
Ortho4XP.cfg
*.cfg
*.ini
*.prefs
*.pref
.last_gui_params.txt

# ── Fichiers de corrections couleur (données locales) ───────
*.ccorr
*.comb

# ── Fichiers DDS / textures (très lourds) ───────────────────
*.dds
*.DDS
*.jpg
*.JPG
*.jpeg

# Exceptions JPG pour Utils/
!Utils/*.jpg
!Utils/*.JPG
!Utils/**/*.jpg
!Utils/**/*.JPG

# ── PNG : ignorer partout SAUF Utils/ et BanniereGithub ─────
# RÈGLE OBLIGATOIRE : exceptions APRÈS la règle *.png
# ET le dossier parent (Utils/) doit être explicitement débloqué
*.png
*.PNG
*.tif
*.tiff
*.geotiff

# Exceptions PNG — ordre impératif : dossier d'abord, fichiers ensuite
!Utils/
!Utils/*.png
!Utils/**/*.png
!BanniereGithub.png

# ── Fichiers mesh et DSF (données de tuiles) ────────────────
*.mesh
*.dsf
*.DSF
*.tri
*.pol

# ── Logs et fichiers temporaires ────────────────────────────
*.log
*.tmp
*.bak
*.backup
log.txt
debug.txt

# ── Python (bytecode compilé) ───────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Environnement virtuel Python ────────────────────────────
venv/
env/
.env/
*.egg-info/
dist/
build/

# ── macOS (fichiers système invisibles) ─────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?
gitignore

# ── Éditeurs de code ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Divers ──────────────────────────────────────────────────
*.zip
*.tar.gz
*.7z
Thumbs.db
_ortho_launch.sh

# ── Lanceurs générés automatiquement ────────────────────────
ORTHO4XP_V2_Lanceur.app/
ORTHO4XP_V3_Lanceur.app/
Lanceur ORTHO4XP.app/
Lanceur_Installation_Prerequis_MAC.zip
Filters/

# ── Données et dossiers locaux perso Ortho4XP ────────────────────────────────
*copie*
Patches/
_backups_O4/
_score_exports/
